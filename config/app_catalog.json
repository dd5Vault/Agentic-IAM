  "respAppProcess": {
    "description": "Processo autorizzativo per abilitazioni applicative — Responsabile Applicativo (RA)",
    "steps": [
      "1. Il richiedente compila il modulo di autorizzazione su AUTHFORMS",
      "2. Il Responsabile Applicativo (RA) approva entro 3 giorni lavorativi",
      "3. Il modulo approvato viene inviato al Team IAM tramite ticket ServiceNow",
      "4. Il Team IAM verifica identità madre su Entra ID",
      "5. Il Team IAM esegue l'abilitazione e notifica via email il richiedente e il RA"
    ],
    "requiredFor":    ["ERPCORE", "ORDERHUB", "NETOPS", "WORKFLOW", "JOBORDER"],
    "notRequiredFor": ["AUTHFORMS", "NETMON", "QUALITY", "WEBPORTAL"],
    "slaHours": 8,
    "escalationAfterHours": 24
  }
}
